{
  "name": "stockledger-local-prototype",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "test": "node --test test/*.test.mjs",
    "build": "vite build",
    "preview": "vite preview --host 127.0.0.1",
    "seed:production": "node scripts/seed-production.mjs",
    "smoke:browser": "node test/browser-smoke.mjs",
    "verify:quick": "npm run test",
    "verify:ui": "node test/verify.mjs --skip-unit --skip-build",
    "verify:build": "npm run build",
    "verify": "node test/verify.mjs",
    "verify:debug": "node test/verify.mjs --keep-server-on-failure"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.0",
    "vite": "^6.0.0"
  },
  "dependencies": {
    "motion": "^11.18.2",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "recharts": "^3.8.1"
  }
}
